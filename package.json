{
  "name": "@richardmcquiston01/unofficial-xcs-writer",
  "version": "0.1.0",
  "description": "Read, write, and apply variable substitution to xTool Creative Space .xcs files",
  "license": "MIT",
  "author": "Richard McQuiston <richard.mcquiston01@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/RichardMcQuiston01/unofficial-xcs-writer.git"
  },
  "homepage": "https://github.com/RichardMcQuiston01/unofficial-xcs-writer#readme",
  "bugs": "https://github.com/RichardMcQuiston01/unofficial-xcs-writer/issues",
  "keywords": ["xtool", "xcs", "laser", "template", "variable-substitution"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
